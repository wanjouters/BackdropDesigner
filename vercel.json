{
  "installCommand": "cd dev/backdrop-designer && npm install",
  "buildCommand": "cd dev/backdrop-designer && npm run build",
  "outputDirectory": "dev/backdrop-designer/dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "0 6 */3 * *"
    }
  ]
}
